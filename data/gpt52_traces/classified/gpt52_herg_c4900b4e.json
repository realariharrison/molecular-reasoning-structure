    {
      "step_id": "38bfe513",
      "step_index": 10,
      "step_type": "reasoning",
      "content": "Most small-molecule hERG blockers bind in the **central cavity** of the channel (open/inactivated states), commonly interacting with aromatic residues (classically **Tyr/Phe** in the S6 region; often described as \u03c0-stacking/cation\u2013\u03c0 contributors).",
      "tool_name": null,
